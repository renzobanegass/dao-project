{
  "name": "dao-project",
  "version": "1.0.0",
  "description": "A Solidity + Next.js DAO demo project",
  "main": "index.js",
  "workspaces": [
    ".",
    "frontend"
  ],
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy": "hardhat run scripts/deploy.ts",
    "start:frontend": "cd frontend && npm run dev",
    "build": "hardhat compile && cd frontend && npm run build",
    "dev": "hardhat node & npm run start:frontend"
  },
  "keywords": ["dao", "solidity", "nextjs", "hardhat", "ethereum"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/node": "^20.0.0",
    "hardhat": "^2.19.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.0",
    "ethers": "^6.8.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.5"
  }
}