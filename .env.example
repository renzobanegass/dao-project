# Ethereum Network URLs
SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Polygon Network URLs
ALCHEMY_POLYGON_MUMBAI_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
INFURA_POLYGON_MUMBAI_URL=https://polygon-mumbai.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Arbitrum Network URLs
ARBITRUM_GOERLI_URL=https://arb-goerli.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Optimism Network URLs
OPTIMISM_GOERLI_URL=https://opt-goerli.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Alternative: Use Infura
# SEPOLIA_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
# MAINNET_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Private Key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Etherscan API Key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Additional block explorer API keys
POLYGONSCAN_KEY=your_polygonscan_api_key_here
ARBISCAN_KEY=your_arbiscan_api_key_here
OPTIMISMSCAN_KEY=your_optimismscan_api_key_here

# Gas Reporter
REPORT_GAS=true

# Coinmarketcap API Key (optional, for gas reporter)
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here